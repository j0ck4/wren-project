<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>@app-id@</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <name>Wren</name>
  <summary>Native GTK4 WireGuard client</summary>

  <description>
    <p>
      Wren is a modern, native GTK4 / libadwaita client for managing
      WireGuard VPN tunnels on Linux.
    </p>
    <p>Features:</p>
    <ul>
      <li>Import .conf files</li>
      <li>One-click connect / disconnect</li>
      <li>System tray indicator</li>
      <li>Live transfer statistics</li>
    </ul>
  </description>

  <launchable type="desktop-id">@app-id@.desktop</launchable>

  <url type="homepage">https://github.com/j0ck4/wren-project</url>
  <url type="bugtracker">https://github.com/j0ck4/wren-project/issues</url>
  <url type="vcs-browser">https://github.com/j0ck4/wren-project</url>

  <developer id="io.github.j0ck4">
    <name>j0ck4</name>
  </developer>

  <content_rating type="oars-1.1"/>

  <screenshots>
    <screenshot type="default">
      <image>https://raw.githubusercontent.com/j0ck4/wren-project/v0.2.1/data/screenshots/wren.png</image>
      <caption>Viewing a tunnel's details in Wren</caption>
    </screenshot>
  </screenshots>

  <branding>
    <color type="primary" scheme_preference="light">#a5c8ff</color>
    <color type="primary" scheme_preference="dark">#1a5fb4</color>
  </branding>

  <releases>
    <release version="0.2.1" date="2026-06-09">
      <description>
        <p>Packaging release: reproducible offline (Flathub) builds and a screenshot in the app metadata. No functional changes since 0.2.0.</p>
      </description>
    </release>
    <release version="0.2.0" date="2026-06-09">
      <description>
        <p>First feature-complete release.</p>
        <ul>
          <li>Import, edit, and delete tunnels</li>
          <li>One-click connect / disconnect with live transfer stats</li>
          <li>Share a tunnel to mobile via QR code</li>
          <li>System tray indicator and start-at-login</li>
        </ul>
      </description>
    </release>
    <release version="0.1.0" date="2026-05-08">
      <description>
        <p>Initial scaffolding.</p>
      </description>
    </release>
  </releases>
</component>
